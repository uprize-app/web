# ============================================================================
# Uprize Frontend — 환경변수 예시
# ----------------------------------------------------------------------------
# 사용법:
#   1) 이 파일을 `.env.local` 로 복사
#   2) 각 값을 아래 설명대로 채움
#   3) .env.local 은 .gitignore 에 이미 포함되어 있음 (커밋 금지)
#
# 규칙:
#   - 프론트 레포에는 NEXT_PUBLIC_ 접두사가 붙은 값만 허용
#   - SERVICE_ROLE / FAL / ANTHROPIC / RESEND 같은 서버 전용 키는
#     절대로 이 파일(또는 .env.local)에 넣지 말 것 — 백엔드 레포 전용
# ============================================================================


# ----------------------------------------------------------------------------
# [필수] 백엔드 API
# ----------------------------------------------------------------------------
# Express 백엔드(uprize-backend)의 base URL.
#   - 로컬 개발: http://localhost:3001  (백엔드 기본 포트 확인 후 조정)
#   - 스테이징/운영: Render 등에서 발급받은 HTTPS URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001


# ----------------------------------------------------------------------------
# [필수] Supabase (브라우저에서 공개돼도 되는 anon key 만)
# ----------------------------------------------------------------------------
# 받는 곳: Supabase Dashboard → Project Settings → API
#   - Project URL        → NEXT_PUBLIC_SUPABASE_URL
#   - Project API keys   → anon public → NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# 주의: service_role 키는 절대 여기 넣지 말 것 (백엔드 전용)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key


# ----------------------------------------------------------------------------
# [Phase C 이후 필수] 카카오맵 JavaScript 키
# ----------------------------------------------------------------------------
# 받는 곳: https://developers.kakao.com → 내 애플리케이션 → 앱 키
#   → "JavaScript 키" 사용 (REST API 키 아님)
#
# 선행 설정:
#   - 플랫폼 → Web 플랫폼 등록에 다음 도메인 추가
#       http://localhost:3000
#       https://<vercel-production-domain>
#   - 카카오맵 API 는 앱 생성만으로 활성화되며 별도 신청 불필요
NEXT_PUBLIC_KAKAO_JS_KEY=your-kakao-javascript-key


# ----------------------------------------------------------------------------
# [개발 전용] 백엔드 인증 우회 스위치
# ----------------------------------------------------------------------------
# 백엔드가 X-Dev-User-Id 헤더를 받아 실제 Supabase Auth 없이도 API 호출을
# 허용함. 카카오 OAuth 는 개발 막판(Phase G)에 붙일 예정이므로 그전까지는
# 이 스위치를 true 로 두고 개발.
#
# 운영 배포 전에 반드시:
#   - NEXT_PUBLIC_USE_DEV_AUTH=false
#   - NEXT_PUBLIC_DEV_USER_ID 값 제거
# 로 바꾸고, Vercel 환경변수에도 false 로 설정할 것.
NEXT_PUBLIC_USE_DEV_AUTH=true

# 백엔드 Supabase 에 미리 만들어둔 테스트 유저의 UUID.
# (backend docs/progress.md 또는 Supabase Auth → Users 에서 확인)
NEXT_PUBLIC_DEV_USER_ID=00000000-0000-0000-0000-000000000000

NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key


# ----------------------------------------------------------------------------
# [선택] 개발 편의 플래그
# ----------------------------------------------------------------------------
# 로그 레벨 / 디버그 스위치 등이 필요해지면 여기에 추가.
# 예)
# NEXT_PUBLIC_DEBUG=true
